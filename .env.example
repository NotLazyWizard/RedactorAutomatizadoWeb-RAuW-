# ============================================================
# GIKINX BOT - Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env a Git o lo compartas
# ============================================================

# --- CORREO (Hostinger IMAP) ---
EMAIL_ADDRESS=luisolmosh@gikinx.mx
EMAIL_PASSWORD=PON_AQUI_TU_PASSWORD_DE_CORREO
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993

# --- GROQ API ---
GROQ_API_KEY=PON_AQUI_TU_GROQ_API_KEY
GROQ_MODEL=llama-3.1-70b-versatile

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=PON_AQUI_TU_TOKEN_DE_TELEGRAM
TELEGRAM_ADMIN_CHAT_ID=PON_AQUI_TU_CHAT_ID

# --- WORDPRESS ---
WP_URL=https://gikinx.mx/wp-json/wp/v2
WP_USER=PON_AQUI_TU_USUARIO_WP
WP_APP_PASSWORD=PON_AQUI_TU_APP_PASSWORD_WP

# --- BASE DE DATOS ---
DATABASE_URL=sqlite:///data/gikinx.db

# --- CONFIGURACIÓN GENERAL ---
CHECK_INTERVAL_MINUTES=30
MAX_REWRITE_ATTEMPTS=3
FEATURED_NEWS_RATIO=4
LOG_LEVEL=INFO
